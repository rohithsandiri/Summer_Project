{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Payment Success rate vs Failure rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(payment_success_total[5m])",
          "legendFormat": "Succeeded",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(payment_failed_total[5m])) by (reason)",
          "legendFormat": "Failed: {{reason}}",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Payment Processing Latency (Seconds)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(payment_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 Processing duration",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "tags": ["microservices", "payment"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Payment Service Metrics Dashboard",
  "version": 1
}
